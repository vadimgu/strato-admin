{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@strato-admin/admin": ["../strato-admin/src"],
      "@strato-admin/cloudscape": ["../strato-cloudscape/src"],
      "@strato-admin/core": ["../strato-core/src"],
      "@strato-admin/faker-ecommerce": ["../strato-faker-ecommerce/src"],
      "@strato-admin/i18n": ["./src"],
      "@strato-admin/language-en": ["../strato-language-en/src"],
      "@strato-admin/language-fr": ["../strato-language-fr/src"]
    },
    "types": ["node"]
  },
  "include": ["src"]
}

{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020",
            "dom"
        ],
        "allowJs": false,
        "jsx": "react",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noImplicitAny": false,
        "noFallthroughCasesInSwitch": true,
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "erasableSyntaxOnly": true,
        "types": ["node", "jest"],
        "outDir": "dist",
        "rootDir": "src",
        "strictNullChecks": true
    },
    "exclude": [
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.spec.js",
        "**/*.stories.ts",
        "**/*.stories.tsx",
        "**/*.stories.js"
    ],
    "include": ["src"]
}
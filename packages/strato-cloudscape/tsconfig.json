{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "types": ["vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@strato-admin/admin": ["../strato-admin/src"],
      "@strato-admin/cloudscape": ["./src"],
      "@strato-admin/core": ["../strato-core/src"],
      "@strato-admin/faker-ecommerce": ["../strato-faker-ecommerce/src"],
      "@strato-admin/i18n": ["../strato-i18n/src"],
      "@strato-admin/language-en": ["../strato-language-en/src"],
      "@strato-admin/language-fr": ["../strato-language-fr/src"]
    }
  },
  "include": ["src"]
}

{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@strato-admin/admin": ["../../packages/strato-admin/src"],
      "@strato-admin/cloudscape": ["../../packages/strato-cloudscape/src"],
      "@strato-admin/core": ["../../packages/strato-core/src"],
      "@strato-admin/faker-ecommerce": ["../../packages/strato-faker-ecommerce/src"],
      "@strato-admin/i18n-cli": ["../../packages/strato-i18n-cli/src"],
      "@strato-admin/i18n": ["../../packages/strato-i18n/src"],
      "@strato-admin/language-en": ["../../packages/strato-language-en/src"],
      "@strato-admin/language-fr": ["../../packages/strato-language-fr/src"]
    },
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
